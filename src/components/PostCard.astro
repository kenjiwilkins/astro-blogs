---
import { Image } from 'astro:assets';
import { type CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';

type Props = {
  post: CollectionEntry<'blog'>;
};

const { post } = Astro.props;
---

<article
  class="group relative flex flex-col bg-surface-container/30 backdrop-blur-xl rounded-3xl p-1 border border-white/5 hover:border-primary/20 transition-all duration-300"
>
  <div class="aspect-video w-full rounded-2xl overflow-hidden mb-6">
    {
      post.data.heroImage && (
        <Image
          alt={post.data.title}
          class="w-full h-full object-cover grayscale opacity-60 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500"
          src={post.data.heroImage}
        />
      )
    }
  </div>
  <div class="px-6 pb-8">
    <div class="flex justify-between items-center mb-4">
      <span
        class="text-[10px] font-label font-bold text-primary tracking-[0.2em] uppercase"
      >
        Engineering
      </span>
      <FormattedDate date={post.data.pubDate} />
    </div>
    <h3
      class="text-xl font-bold font-headline leading-snug mb-3 group-hover:text-secondary transition-colors"
    >
      {post.data.title}
    </h3>
    {
      post.data.description && (
        <p class="text-on-surface-variant/70 text-sm line-clamp-2 mb-6">
          {post.data.description}
        </p>
      )
    }
  </div>
  <div class="flex items-center justify-between">
    <a
      class="text-primary text-xs font-label font-bold flex items-center gap-2 group-hover:translate-x-1 transition-transform"
      href={`/blog/${post.id}/`}
    >
      VIEW CASE STUDY
      <span class="material-symbols-outlined text-sm">arrow_forward</span>
    </a>
  </div>
</article>
