---
import { Image } from 'astro:assets';
import { type CollectionEntry } from 'astro:content';

type Props = {
  post: CollectionEntry<'blog'>;
};

const { post } = Astro.props;
---

<a
  href={`/blog/${post.id}/`}
  class="glass-card p-6 rounded-3xl flex flex-col gap-4 group"
>
  {
    post.data.heroImage && (
      <div class="h-40 rounded-2xl overflow-hidden relative">
        <Image
          alt={post.data.title}
          class="w-full h-40 object-cover scale-100 group-hover:scale-110 transition-transform duration-700"
          src={post.data.heroImage}
        />
      </div>
    )
  }
  <div>
    <div class="flex flex-wrap gap-1.5 mb-1">
      {post.data.tags.map((tag: string) => (
        <span class="text-secondary font-label text-[10px] tracking-widest uppercase">
          {tag}
        </span>
      ))}
    </div>
    <h4 class="font-headline font-bold text-lg text-on-surface">
      {post.data.title}
    </h4>
  </div>
</a>
