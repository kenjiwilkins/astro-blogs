---
import { Image } from 'astro:assets';
import { type CollectionEntry } from 'astro:content';

type Props = {
  post: CollectionEntry<'blog'>;
};

const { post } = Astro.props;
---

<a
  href={`/blog/${post.id}/`}
  class="glass-card p-6 rounded-3xl flex flex-col gap-4 group"
>
  {
    post.data.heroImage && (
      <div class="h-40 rounded-2xl overflow-hidden">
        <Image
          alt={post.data.title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform"
          src={post.data.heroImage}
        />
      </div>
    )
  }
  <div>
    <span
      class="text-secondary font-label text-[10px] tracking-widest uppercase mb-1 block"
    >
      Engineering
    </span>
    <h4 class="font-headline font-bold text-lg text-on-surface">
      {post.data.title}
    </h4>
  </div>
</a>
