---
interface Props {
  framework: string;
  directive: string;
  borderColor: string;
  description: string;
}

const { framework, directive, borderColor, description } = Astro.props;
---

<div
  class:list={[
    'glass-card p-8 rounded-3xl relative',
    'border-l-4',
    borderColor,
  ]}
>
  <div class="flex justify-between items-start mb-2">
    <span
      class="font-label text-[10px] uppercase tracking-[0.3em] text-on-surface-variant/50"
    >
      {directive}
    </span>
    <span
      class="px-3 py-1 rounded-full text-[10px] font-label font-bold uppercase tracking-widest bg-white/5 border border-white/10 text-on-surface-variant/70"
    >
      {framework}
    </span>
  </div>
  <p class="text-xs text-on-surface-variant/50 mb-6 font-body">{description}</p>
  <slot />
</div>
