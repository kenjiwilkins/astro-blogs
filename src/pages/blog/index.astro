---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import Sidebar from '../../components/SideNavigation.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { Rss} from '@lucide/astro'

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body
    class="bg-background text-on-background font-body selection:bg-primary-container selection:text-on-primary-container"
  >
    <Header />
    <Sidebar />
    <main class="pt-32 pb-20 px-6 lg:ml-72 max-w-7xl mx-auto">
      <!-- Header Section -->
      <header class="mb-16">
        <div
          class="flex flex-col md:flex-row md:items-end justify-between gap-6"
        >
          <div>
            <span
              class="font-label text-secondary text-sm font-bold tracking-[0.3em] uppercase mb-4 block"
              >Archive Index</span
            >
            <button
              class="inline-flex items-center gap-2 px-4 py-2 mb-6 rounded-full border border-primary/20 bg-primary/5 backdrop-blur-md text-primary hover:bg-primary/10 hover:shadow-[0_0_20px_rgba(0,240,255,0.2)] transition-all group"
            >
              <Rss class="text-sm group-active:scale-90 transition-transform" />
              <span
                class="font-label text-[10px] font-bold tracking-[0.2em] uppercase"
                >RSS Feed</span
              >
            </button>
            <h1
              class="text-5xl md:text-7xl font-black font-headline tracking-tighter leading-none"
            >
              The Refracted<br /><span class="text-primary">Narrative.</span>
            </h1>
          </div>
          <!-- Glass Filtering Chips -->
          <div class="flex flex-wrap gap-2 pb-2">
            <button
              class="px-5 py-2 rounded-full border border-primary/20 bg-primary/5 text-primary text-xs font-label font-bold hover:bg-primary/20 hover:shadow-[0_0_15px_rgba(0,240,255,0.3)] transition-all"
              >#all_entries</button
            >
            <button
              class="px-5 py-2 rounded-full border border-white/5 bg-surface-container text-on-surface-variant text-xs font-label hover:border-secondary/50 hover:text-secondary transition-all"
              >#rust</button
            >
            <button
              class="px-5 py-2 rounded-full border border-white/5 bg-surface-container text-on-surface-variant text-xs font-label hover:border-secondary/50 hover:text-secondary transition-all"
              >#brutalist_ui</button
            >
            <button
              class="px-5 py-2 rounded-full border border-white/5 bg-surface-container text-on-surface-variant text-xs font-label hover:border-secondary/50 hover:text-secondary transition-all"
              >#webgpu</button
            >
            <button
              class="px-5 py-2 rounded-full border border-white/5 bg-surface-container text-on-surface-variant text-xs font-label hover:border-secondary/50 hover:text-secondary transition-all"
              >#architecture</button
            >
          </div>
        </div>
      </header>
      <!-- Featured Post Card -->
      <section class="mb-20">
        <div
          class="relative group rounded-3xl overflow-hidden glass-liquid-mesh border border-white/5 shadow-2xl"
        >
          <div
            class="absolute inset-0 bg-gradient-to-br from-primary/10 via-transparent to-secondary/10 opacity-50 group-hover:opacity-100 transition-opacity"
          >
          </div>
          <div class="flex flex-col lg:flex-row min-h-[500px]">
            <div class="lg:w-1/2 relative overflow-hidden">
              <img
                alt="Featured Post"
                class="w-full h-full object-cover scale-105 group-hover:scale-100 transition-transform duration-700"
                data-alt="Abstract rendering of crystalline structures with glowing blue and purple light refractions, cinematic depth of field, high-tech aesthetic"
                src="https://lh3.googleusercontent.com/aida-public/AB6AXuAfxqkEXkYjxJxXjkBpJGCjvOgoyIso_Ye1Y3jrH2d4SSo_aHW1QMq-2ZmLnHlwubS7fhTt5E-1ElGxG5wcBF60PJBvLV2Ha_ThTF9i0nzMykm8TTAlJxz3NysTRdYuX8J8IFaXXKx3m4leBl83l0DXUzRHv-vqXReIN0N04fTwRfMUy71qfnORDSv5uO2QLnEAmdWlYzbBY07lzCaH6IuvL9VkQRVvDFuunTtRoxV8Z_B_soR-n7ym6YnkU2Kg6xL9-yJrUCM40LU"
              />
              <div
                class="absolute inset-0 bg-gradient-to-r from-background via-transparent to-transparent hidden lg:block"
              >
              </div>
            </div>
            <div
              class="lg:w-1/2 p-10 md:p-16 flex flex-col justify-center relative z-10 backdrop-blur-sm"
            >
              <div class="flex items-center gap-3 mb-6">
                <span
                  class="px-3 py-1 rounded bg-secondary/20 text-secondary font-label text-[10px] font-bold tracking-widest uppercase"
                  >Deep Dive</span
                >
                <span class="text-on-surface-variant/40 text-xs font-label"
                  >12 MIN READ</span
                >
              </div>
              <h2
                class="text-4xl md:text-5xl font-black font-headline tracking-tighter leading-tight mb-6 group-hover:text-primary transition-colors"
              >
                Architecting the Liquid Component System
              </h2>
              <p
                class="text-on-surface-variant text-lg leading-relaxed mb-8 max-w-md"
              >
                How refraction-based UI patterns are redefining the boundary
                between data and human interaction in the modern browser.
              </p>
              <div class="flex items-center gap-4">
                <button
                  class="px-8 py-3 rounded-full bg-gradient-to-r from-primary to-secondary text-on-primary font-bold tracking-tight hover:shadow-[0_0_30px_rgba(143,245,255,0.4)] transition-all"
                  >Read Manuscript</button
                >
                <button
                  class="material-symbols-outlined text-on-surface-variant hover:text-primary transition-colors"
                  >bookmark</button
                >
                <button
                  class="material-symbols-outlined text-on-surface-variant hover:text-primary transition-colors"
                  >share</button
                >
              </div>
            </div>
          </div>
        </div>
      </section>
      <!-- Archive List (Bento-ish Grid) -->
      <section
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-20"
      >
        {
          posts.map((post) => (
            <article class="group relative flex flex-col bg-surface-container/30 backdrop-blur-xl rounded-3xl p-1 border border-white/5 hover:border-primary/20 transition-all duration-300">
              <div class="aspect-video w-full rounded-2xl overflow-hidden mb-6">
                {post.data.heroImage && (
                  <Image
                    alt="Post Thumbnail"
                    class="w-full h-full object-cover grayscale opacity-60 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500"
                    src={post.data.heroImage}
                  />
                )}
              </div>
              <div class="px-6 pb-8">
                <div class="flex justify-between items-center mb-4">
                  <span class="text-[10px] font-label font-bold text-primary tracking-[0.2em] uppercase">
                    Engineering
                  </span>
                  <FormattedDate date={post.data.pubDate} />
                </div>
                <h3 class="text-xl font-bold font-headline leading-snug mb-3 group-hover:text-secondary transition-colors">
                  {post.data.title}
                </h3>
                <p class="text-on-surface-variant/70 text-sm line-clamp-2 mb-6">
                  Exploring the performance gains of offloading heavy
                  computations to the client-side via WebAssembly modules.
                </p>
              </div>
              <div class="flex items-center justify-between">
                <a
                  class="text-primary text-xs font-label font-bold flex items-center gap-2 group-hover:translate-x-1 transition-transform"
                  href="#"
                >
                  VIEW CASE STUDY{' '}
                  <span class="material-symbols-outlined text-sm">
                    arrow_forward
                  </span>
                </a>
              </div>
            </article>
          ))
        }
      </section>
      <Footer />
    </main>
  </body>
</html>
