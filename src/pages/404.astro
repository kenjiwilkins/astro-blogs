---
import { House } from '@lucide/astro';
import BaseHead from '../components/BaseHead.astro';
import GoBackButton from '../components/GoBackButton';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Page Not Found"
      description="The page you are looking for does not exist."
    />
    <meta name="robots" content="noindex, follow" />
  </head>
  <body
    class="bg-background text-on-surface font-body overflow-x-hidden selection:bg-primary/30 min-h-screen flex flex-col"
  >
    <!-- Main Content Canvas -->
    <main
      class="grow relative overflow-hidden flex flex-col items-center justify-center px-6 py-20"
    >
      <!-- Ambient Liquid Gradients -->
      <div class="absolute inset-0 z-0 pointer-events-none">
        <div
          class="absolute top-[-10%] left-[-10%] w-[60%] h-[60%] rounded-full liquid-mesh opacity-40"
        >
        </div>
        <div
          class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] rounded-full bg-secondary/10 blur-[120px]"
        >
        </div>
        <div
          class="absolute top-[20%] right-[10%] w-[30%] h-[30%] rounded-full bg-tertiary/10 blur-[100px]"
        >
        </div>
      </div>
      <!-- Hero Content Layer -->
      <div class="relative z-10 max-w-4xl w-full text-center space-y-8">
        <!-- Large Liquid Typography 404 -->
        <div class="relative inline-block">
          <h1
            class="font-headline font-extrabold text-9xl leading-none tracking-tighter text-transparent bg-clip-text bg-linear-to-b from-primary via-secondary to-tertiary select-none opacity-90 filter drop-shadow-[0_0_40px_rgba(0,238,252,0.3)]"
          >
            404
          </h1>
          <!-- Refraction Lens Overlay -->
          <div
            class="absolute inset-0 bg-white/5 backdrop-blur-[2px] rounded-full scale-110 pointer-events-none"
            style="mask-image: radial-gradient(circle, black, transparent 70%);"
          >
          </div>
        </div>
        <!-- Error Message -->
        <div class="space-y-4">
          <div
            class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-surface-variant/30 border border-outline-variant/20 backdrop-blur-md"
          >
            <span
              class="material-symbols-outlined text-error text-sm"
              style="font-variation-settings: 'FILL' 1;">ERROR</span
            >
            <span
              class="font-label text-xs uppercase tracking-[0.2em] text-on-surface-variant"
            >
              MISSED CONNECTION
            </span>
          </div>
          <h2
            class="font-headline text-4xl md:text-6xl font-bold tracking-tight text-on-surface"
          >
            SYSTEM ERROR: <span class="text-primary-dim">PAGE NOT FOUND</span>
          </h2>
          <p
            class="max-w-xl mx-auto text-lg text-on-surface-variant font-light leading-relaxed"
          >
            The core has been breached. The data you are looking for has shifted
            into a higher dimensional plane or simply never existed in this
            iteration.
          </p>
        </div>
        <!-- Action Area -->
        <div
          class="pt-8 flex flex-col md:flex-row items-center justify-center gap-6"
        >
          <!-- Primary Action: Liquid Capsule -->
          <a
            class="group relative px-10 py-4 rounded-full bg-linear-to-r from-primary to-secondary text-on-primary font-headline font-semibold text-lg glass-bead overflow-hidden transition-all duration-300 hover:scale-105 hover:shadow-[0_0_30px_rgba(143,245,255,0.4)] active:scale-95"
            href="/"
          >
            <span class="relative z-10 flex items-center gap-2">
              <House class="w-5 h-5" />
              HOME
            </span>
            <!-- Gloss Swipe -->
            <div
              class="absolute inset-0 w-full h-full bg-linear-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700 ease-in-out"
            >
            </div>
          </a>
          <!-- Secondary Action: React Client Island -->
          <GoBackButton client:load />
        </div>
      </div>
    </main>
  </body>
</html>
