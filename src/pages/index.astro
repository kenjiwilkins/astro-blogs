---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BackgroundOrbs from '../components/BackgroundOrbs.astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import MetricCard from '../components/MetricCard.astro';
import Sidebar from '../components/SideNavigation.astro';
import TimeSinceMetric from '../components/TimeSinceMetric';
import TransmissionCard from '../components/TransmissionCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const totalPosts = posts.length;
const totalTags = new Set(posts.flatMap((p) => p.data.tags)).size;
const totalWords = posts.reduce((sum, p) => sum + (p.body?.split(/\s+/).length ?? 0), 0);
const latestPubDate = posts[0]?.data.pubDate.toISOString();

const metrics = [
  {
    icon: 'article',
    label: 'Total Posts',
    value: String(totalPosts),
    note: `Across ${totalTags} tags`,
    color: 'primary' as const,
  },
  {
    icon: 'sell',
    label: 'Total Tags',
    value: String(totalTags),
    note: 'Content categories',
    color: 'secondary' as const,
  },
  {
    icon: 'text_fields',
    label: 'Words Written',
    value: totalWords >= 1000 ? `${(totalWords / 1000).toFixed(1)}k` : String(totalWords),
    note: 'And counting',
    color: 'primary' as const,
  },
];

const featuredPost = posts[0];
const secondaryPosts = posts.slice(1, 3);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body
    class="bg-background text-on-surface font-body overflow-x-hidden selection:bg-primary/30"
  >
    <Header />
    <Sidebar />
    <main
      class="lg:pl-72 pt-28 px-8 pb-20 relative overflow-hidden min-h-screen"
    >
      <!-- Liquid Background Orbs -->
      <BackgroundOrbs />
      <!-- Hero Section -->
      <section class="mb-24 relative">
        <div
          class="glass-card p-12 lg:p-20 rounded-[2.5rem] overflow-hidden relative group gloss-swipe"
        >
          <div class="absolute inset-0 liquid-mesh opacity-50 -z-10"></div>
          <div class="max-w-4xl relative z-10">
            <span
              class="font-label text-primary font-bold tracking-[0.3em] uppercase mb-6 block"
              >Refraction Engine v4.0</span
            >
            <h1
              class="font-headline text-5xl md:text-7xl lg:text-8xl font-black tracking-tighter mb-8 leading-[0.9] text-on-surface"
            >
              <span class="text-4xl md:text-6xl lg:text-7xl">世の中は</span
              ><span
                class="bg-clip-text text-transparent bg-gradient-to-r from-primary via-secondary to-tertiary"
                ><br />えくぼもあばた</span
              >
            </h1>
            <p
              class="font-body text-xl text-on-surface-variant max-w-2xl mb-12 leading-relaxed"
            >
              うらやむ気持ちはあふれたそばから妬みへと腐敗していく。<br />
            </p>
            <div class="flex flex-wrap gap-6">
              <a
                class="px-10 py-4 bg-gradient-to-r from-primary to-secondary text-on-primary font-headline font-bold rounded-full shadow-[0_0_20px_rgba(0,238,252,0.3)] hover:scale-105 transition-transform relative overflow-hidden"
                href="/blog/"
              >
                <span class="relative z-10">読んでみちゃう</span>
                <div class="absolute top-0 left-0 w-full h-[1px] bg-white/40">
                </div>
              </a>
            </div>
          </div>
        </div>
      </section>
      <!-- Metrics Grid -->
      <section class="mb-24">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {metrics.map((metric) => <MetricCard {...metric} />)}
          <TimeSinceMetric client:visible date={latestPubDate} />
        </div>
      </section>
      <!-- Content Grid (Latest Transmissions) -->
      <section class="mb-24">
        <div class="flex items-end justify-between mb-12">
          <div>
            <h2
              class="font-headline text-4xl font-black text-on-surface tracking-tight mb-2"
            >
              Latest Transmissions
            </h2>
            <p class="text-on-surface-variant font-body">
              Deep dives into the liquid stack
            </p>
          </div>
          <button
            class="font-label text-sm text-primary hover:tracking-widest transition-all duration-300 flex items-center gap-2"
          >
            VIEW ALL <span class="material-symbols-outlined text-sm"
              >arrow_forward</span
            >
          </button>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
          <!-- Featured Card -->
          {
            featuredPost && (
              <a
                href={`/blog/${featuredPost.id}/`}
                class="md:col-span-8 group relative overflow-hidden rounded-[2rem] block"
              >
                <div class="absolute inset-0 bg-gradient-to-t from-background via-transparent to-transparent z-10" />
                {featuredPost.data.heroImage && (
                  <Image
                    alt={featuredPost.data.title}
                    class="w-full h-[500px] object-cover transition-transform duration-700 group-hover:scale-110"
                    src={featuredPost.data.heroImage}
                  />
                )}
                <div class="absolute bottom-0 left-0 p-10 z-20">
                  <span class="bg-primary/20 backdrop-blur-md text-primary font-label text-xs px-3 py-1 rounded-full mb-4 inline-block">
                    ENGINEERING
                  </span>
                  <h3 class="font-headline text-4xl font-bold text-white mb-4 leading-tight">
                    {featuredPost.data.title}
                  </h3>
                  <p class="text-on-surface/80 max-w-xl mb-6 font-body">
                    {featuredPost.data.description}
                  </p>
                  <span class="flex items-center gap-3 font-headline font-bold text-white group-hover:gap-5 transition-all">
                    Read transmission{' '}
                    <span class="material-symbols-outlined">east</span>
                  </span>
                </div>
              </a>
            )
          }
          <!-- Secondary Cards Stack -->
          <div class="md:col-span-4 flex flex-col gap-8">
            {secondaryPosts.map((post) => <TransmissionCard post={post} />)}
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
