---
import AboutHeroImage from '../assets/blog-placeholder-about.jpg';
import IslandCard from '../components/IslandCard.astro';
import MoodPicker from '../components/react/MoodPicker';
import CharacterCounter from '../components/vue/CharacterCounter.vue';
import ColorMixer from '../components/svelte/ColorMixer.svelte';
import Stopwatch from '../components/solid/Stopwatch';
import Layout from '../layouts/BlogPost.astro';
---

<Layout
  title="About & Island Demos"
  description="Demonstrating Astro's client island architecture with React, Vue, Svelte, and Solid"
  pubDate={new Date('August 08 2021')}
  heroImage={AboutHeroImage}
  tags={[]}
  prevPost={null}
  nextPost={null}
>
  <p>
    Astro's <strong>Island Architecture</strong> lets you use components from any
    UI framework — each hydrating independently with its own
    <code>client:*</code> directive. Below are four interactive islands, each
    built with a different framework and hydration strategy.
  </p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-12 not-prose">
    <IslandCard
      framework="React"
      directive="client:load"
      borderColor="border-primary"
      description="Hydrates immediately on page load. Best for above-the-fold interactive content."
    >
      <MoodPicker client:load />
    </IslandCard>

    <IslandCard
      framework="Vue"
      directive="client:visible"
      borderColor="border-secondary"
      description="Hydrates when scrolled into the viewport. Saves resources for below-the-fold content."
    >
      <CharacterCounter client:visible />
    </IslandCard>

    <IslandCard
      framework="Svelte"
      directive="client:idle"
      borderColor="border-tertiary"
      description="Hydrates when the browser is idle. Good for non-critical interactive elements."
    >
      <ColorMixer client:idle />
    </IslandCard>

    <IslandCard
      framework="Solid"
      directive="client:only"
      borderColor="border-error"
      description="Renders only on the client — no server HTML. Useful for browser-only APIs."
    >
      <Stopwatch client:only="solid-js" />
    </IslandCard>
  </div>
</Layout>
